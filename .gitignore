# Workspace .gitignore - F's OpenClaw agent (Frank's team bot)
# 2026-06-12: 锁定 UTF-8 双重编码防御 SOP B 项 配套
# 只 track .md (UTF-8 no BOM baseline) + scripts/，其余 noise 不进 git

# Workdirs and runtime noise
tmp/
__pycache__/
*.pyc
*.wasm
*.map

# F's internal ephemeral state (regenerated by OpenClaw)
memory/.dreams/
memory/.dreams/**

# Hidden config / cache dirs
.clawhub/
.openclaw/
.wrangler/

# Media (audio/video) and large docs - rarely operational for F
*.wav
*.mp3
*.mp4
*.pdf

# Editor / OS
.vscode/
.idea/
.DS_Store
Thumbs.db
